#!/bin/bash
set -euo pipefail

################################################################################
## Constants
################################################################################

readonly RED='\033[0;31m'
readonly RESET='\033[0m'
readonly VERSION_FILE="lib/enum_fields/version.rb"
readonly CHANGELOG_FILE="CHANGELOG.md"
readonly UNRELEASED_HEADER="## [X.X.X] - YYYY-MM-DD"

################################################################################
## Cleanup
################################################################################

trap 'echo -e "\n${RED}ERROR: Something went wrong!${RESET}" >&2' ERR
trap 'echo -e "\n${RED}ERROR: The process was interrupted!${RESET}" >&2; exit 1' INT TERM

################################################################################
## Functions
################################################################################

function current_version() {
  sed -n 's/.*VERSION = "\([^"]*\)".*/\1/p' "$VERSION_FILE"
}

function prompt_version() {
  local current="$1"

  gum input \
    --header "Current version: $current" \
    --placeholder "Enter new version (e.g. 0.4.0)" \
    --value "$current"
}

function update_version_file() {
  local old_version="$1"
  local new_version="$2"

  sed -i '' "s/VERSION = \"$old_version\"/VERSION = \"$new_version\"/" "$VERSION_FILE"
}

function update_changelog() {
  local new_version="$1"
  local today
  today=$(date +%Y-%m-%d)

  perl -i -pe "s/\\Q${UNRELEASED_HEADER}\\E/${UNRELEASED_HEADER}\n\n## [${new_version}] - ${today}/" "$CHANGELOG_FILE"
}

################################################################################
## Execution
################################################################################

old_version=$(current_version)
new_version=$(prompt_version "$old_version")

if [[ "$old_version" == "$new_version" ]]; then
  echo -e "${RED}ERROR: Version unchanged${RESET}"
  exit 1
fi

gum confirm "Release enum_fields v${new_version}?" || exit 0

update_version_file "$old_version" "$new_version"
echo "✓ Updated $VERSION_FILE to $new_version"

update_changelog "$new_version"
echo "✓ Updated $CHANGELOG_FILE for $new_version"

git add "$VERSION_FILE" "$CHANGELOG_FILE"
git commit -m "Bump version to $new_version"
git push
echo "✓ Committed and pushed"

rake release || true
gem push "pkg/enum_fields-${new_version}.gem"
echo "✓ Released enum_fields v${new_version}"
